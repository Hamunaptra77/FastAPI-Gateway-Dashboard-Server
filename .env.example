# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_NAME=FastAPI License Gateway
APP_ENV=development            # development | production
APP_DEBUG=false                # Set to false in production
# REQUIRED: generate a strong random value; placeholder values are rejected at runtime
APP_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_HEX_STRING
DATABASE_URL=sqlite:///./licenses.db   # Use postgresql+psycopg2://... in production
APP_BASE_URL=http://localhost:8000

# ──────────────────────────────────────────────
# PayPal
# ──────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=sandbox            # sandbox | live
PAYPAL_WEBHOOK_ID=your_webhook_id

# ──────────────────────────────────────────────
# Pricing (EUR)
# ──────────────────────────────────────────────
PLAN_MONTHLY_PRICE_EUR=9.99
PLAN_YEARLY_PRICE_EUR=29.00
PLAN_LIFETIME_PRICE_EUR=99.00

# ──────────────────────────────────────────────
# Trial / Rate Limiting
# ──────────────────────────────────────────────
TRIAL_INACTIVE_DELETE_AFTER_DAYS=30
TRIAL_CLEANUP_INTERVAL_SECONDS=3600
TRIAL_RATE_LIMIT_WINDOW_SECONDS=60
TRIAL_RATE_LIMIT_MAX_REQUESTS=3

# ──────────────────────────────────────────────
# Brute-Force Protection
# ──────────────────────────────────────────────
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_MINUTES=15

# ──────────────────────────────────────────────
# Session
# ──────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=60

# ──────────────────────────────────────────────
# SMTP (optional)
# ──────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# ──────────────────────────────────────────────
# Admin Credentials (REQUIRED – change before first start)
# ──────────────────────────────────────────────
# IMPORTANT: Must be at least 10 chars, containing upper/lowercase, digit, and symbol.
DEFAULT_SUPERADMIN_USERNAME=admin
DEFAULT_SUPERADMIN_PASSWORD=CHANGE_ME_Strong1!
# Leave both support values empty to disable automatic support-user seeding.
DEFAULT_SUPPORT_USERNAME=support
DEFAULT_SUPPORT_PASSWORD=CHANGE_ME_Strong2!
